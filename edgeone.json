{
  "$schema": "https://edgeone.cloud.tencent.com/pages/schemas/edgeone.schema.json",
  "framework": "static",
  "buildCommand": "cd engine && npm ci && npm run build",
  "outputDir": "engine/dist",
  "installCommand": "true",
  "rewrites": [
    { "source": "/players", "destination": "/players.html" }
  ],
  "headers": [
    {
      "source": "/voice/(.*).mp3",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800, immutable" }
      ]
    },
    {
      "source": "/(game|players).bundle.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    }
  ]
}
